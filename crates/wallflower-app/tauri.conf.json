{
  "$schema": "https://raw.githubusercontent.com/niclas-niclas/tauri-v2-schema/main/schema.json",
  "productName": "Wallflower",
  "version": "0.2.0",
  "identifier": "com.wallflower.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../out"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "13.0"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Wallflower",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/wallflower/**"]
      }
    }
  }
}
